<?xml version="1.0" encoding="utf-8"?>

<pretext xml:lang="en-US" xmlns:xi="http://www.w3.org/2001/XInclude">
  <book xml:id="my-great-book">
    <title>My Great Book</title>
    <subtitle>to help hyperlinks get underlined</subtitle>

    <frontmatter>
      <!-- Table of contents is automatic. This just generates the title page--> 
      <titlepage>
        <titlepage-items/>
      </titlepage>
    </frontmatter>


    <chapter xml:id="chapter1" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Hyperlinks</title>
    <introduction><p>How to make hyperlinks in PreTeXt</p></introduction>
    <section xml:id="section0">
      <title>Introduction</title>
      <p>To make a hyperlink in PreTeXt</p>
    </section>
    <section xml:id="section1">
      <title>Hyperlink Example</title>
      <subtitle>Testing section subtitles</subtitle>
      <p>Here is an example of a hyperlink to <url href="https://www.google.com">Google</url> using the <em>url</em> command.</p>
    </section>
    <section xml:id="section2">
      <title>Another Hyperlink Example</title>
      <p>Here is another example of a hyperlink except we're going to refer to <xref ref="section1"/> using the <em>xref</em> command.</p>
    </section>

    <section xml:id="table">
      <title>A Table</title>
      <p>Here is a table
        <table xml:id="table-edf-thrust-data">
    <title>EDF Propulsion System: Thrust vs. Current</title>
    <tabular>
        <row header="yes" bottom="medium">
            <cell>Throttle (%)</cell>
            <cell>Current (A)</cell>
            <cell>Voltage (V)</cell>
            <cell>Thrust (gf)</cell>
        </row>
        
        <row>
            <cell>25</cell>
            <cell>4.2</cell>
            <cell>12.4</cell>
            <cell>180</cell>
        </row>
        <row highlight="green">
            <cell colors="red">50</cell>
            <cell><alert>12.8</alert></cell>
            <cell>11.9</cell>
            <cell>450</cell>
        </row>
        <row bg-color="yellow!50">
            <cell>75</cell>
            <cell>28.5</cell>
            <cell>11.2</cell>
            <cell>820</cell>
        </row>
        <row>
            <cell>100</cell>
            <cell>45.2</cell>
            <cell>10.5</cell>
            <cell>1150</cell>
        </row>
    </tabular>
</table>
</p>
</section>

<section xml:id="sec-list-example">
  <title>list example</title>
  <p>Here is an example of a list</p>
  <ol>
    <li><p>First item</p></li>
    <li><p>Second item</p></li>
  </ol> 
  <ul>
    <li><p>First item in unordered list</p> </li>
    <li><p>Second item in unordered list</p> </li>
  </ul>
  <dl>
    <li><title>First:</title><p>Item</p></li>
    <li><title>Second:</title><p>Item</p></li>
  </dl>
  <list xml:id="my-list">
    <title>My List</title>
    <ol>
    <li><p>First item in list</p></li>
    <li><p>Second item in list</p></li>
  </ol>
</list>
</section>

    </chapter>
    </book>
</pretext>
